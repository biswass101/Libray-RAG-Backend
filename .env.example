# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=library_db

# Prisma connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/library_db?schema=public"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_ACCESS_SECRET="super-secret-access-key-change-me"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# OpenRouter Configuration for RAG (https://openrouter.ai)
OPENROUTER_API_KEY="sk-or-v1-YOUR_API_KEY"
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_EMBEDDING_MODEL="text-embedding-3-small"

# Server Port
PORT=4000
